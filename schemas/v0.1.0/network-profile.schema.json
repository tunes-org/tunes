{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tunes.dev/schemas/v0.1.0/network-profile.schema.json",
  "title": "TUNES network profile (instance data)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "network_profile_id",
    "city",
    "transport_system",
    "lines",
    "stations",
    "sections"
  ],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "network_profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9._@-]+$",
      "description": "e.g. london-underground@2026-07-20"
    },
    "city": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "transport_system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "branch_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "stations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "line_id", "from_station_id", "to_station_id", "direction_id"],
        "properties": {
          "id": { "type": "string" },
          "line_id": { "type": "string" },
          "from_station_id": { "type": "string" },
          "to_station_id": { "type": "string" },
          "direction_id": { "type": "string" },
          "direction_label": { "type": "string" },
          "typical_duration_seconds": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
